# Copy to .env and fill in values. Do not commit .env.

# Database (default SQLite for local)
DATABASE_URL=sqlite:///./sql_app.db

# API auth for /api/calls (Python backend)
# API_KEY=your-api-key

# Twilio (see docs/setup/twilio_media_streams.md)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Public WebSocket URL for Media Streams (wss://your-host/media). Required for /voice TwiML.
TWILIO_MEDIA_STREAM_WS_URL=

# Optional: require token for WebSocket connections (query ?token= or header X-Twilio-Token)
# WS_AUTH_TOKEN=

# Google Cloud (STT, Gemini, TTS). See docs and GCP setup.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_TTS_VOICE_NAME= (optional; default en-US-Neural2-D; set to Custom Voice name when ready)

# Node.js server port (default 8080)
# PORT=8080
